{
    "name": "hiblaphp/redis",
    "description": "High Performance Non-Blocking Pure PHP Redis Client",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hibla\\Redis\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "hiblaphp/event-loop": "^1.0",
        "hiblaphp/stream": "^1.0",
        "hiblaphp/dns": "^1.0",
        "hiblaphp/cache": "^1.0",
        "hiblaphp/socket": "^1.0",
        "hiblaphp/promise": "^1.0",
        "hiblaphp/async": "^1.0",
        "hiblaphp/cancellation": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.10",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "mockery/mockery": "^1.6"
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "format": "./vendor/bin/pint",
        "format-test": "./vendor/bin/pint --test",
        "analyze": "./vendor/bin/phpstan analyse",
        "generate-certs": [
            "mkdir -p tests/Fixtures/ssl",
            "openssl req -newkey rsa:2048 -nodes -keyout tests/Fixtures/ssl/server-key.pem -x509 -days 365 -out tests/Fixtures/ssl/server-cert.pem -subj \"/CN=127.0.0.1\"",
            "cp tests/Fixtures/ssl/server-cert.pem tests/Fixtures/ssl/ca.pem",
            "chmod 644 tests/Fixtures/ssl/*"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}